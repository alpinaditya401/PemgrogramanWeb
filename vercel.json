{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "headers": [
    {
      "source": "/Assets/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/octet-stream" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/Assets/(.*)", "destination": "/api/Assets/$1" },
    { "source": "/uploads/(.*)", "destination": "/api/uploads/$1" },
    { "source": "/", "destination": "/api/index.php" },
    { "source": "/index.php", "destination": "/api/index.php" },
    { "source": "/Proses/:path*.php", "destination": "/api/Proses/:path*.php" },
    { "source": "/:path*.php", "destination": "/api/:path*.php" }
  ]
}
