{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/api/index.php"
    },
    {
      "src": "/index.php",
      "dest": "/api/index.php"
    },
    {
      "src": "/api/Proses/(.*)\\.php",
      "dest": "/api/Proses/$1.php"
    },
    {
      "src": "/api/([^/]+\\.php)(.*)",
      "dest": "/api/$1$2"
    },
    {
      "src": "/([^/]+\\.php)(.*)",
      "dest": "/api/$1$2"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
